{
  "name": "lampstand",
  "main": "src/workers/static-spa.ts",
  "compatibility_date": "2026-04-09",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "thelampstand.icu/*",
      "zone_name": "thelampstand.icu"
    },
    {
      "pattern": "www.thelampstand.icu/*",
      "zone_name": "thelampstand.icu"
    }
  ],
  "unsafe": {
    "bindings": [
      {
        "name": "RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1001",
        "simple": {
          "limit": 60,
          "period": 60
        }
      }
    ]
  }
}
