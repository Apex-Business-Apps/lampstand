VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Server-side secrets — set these in Supabase Dashboard > Project Settings > Edge Functions > Secrets
# GROQ_API_KEY — never put this in .env or commit it; set it as a Supabase secret only
# ELEVENLABS_API_KEY — same; set as a Supabase secret only
