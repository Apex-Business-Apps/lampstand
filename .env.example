VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Publishable key — copy from Supabase Dashboard > API Keys > "Publishable and secret API keys" tab.
# Use the NEW sb_publishable_* format (e.g. sb_publishable_xxxx).
# Do NOT use the legacy "anon" JWT from the "Legacy anon, service_role API keys" tab —
# that is a separate, older credential. Supabase recommends the publishable key for all new setups.
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxx"

# Server-side secrets — set these in Supabase Dashboard > Project Settings > Edge Functions > Secrets
# GROQ_API_KEY — never put this in .env or commit it; set it as a Supabase secret only
# ELEVENLABS_API_KEY — same; set as a Supabase secret only
